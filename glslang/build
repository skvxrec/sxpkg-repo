#!/bin/sh
# GCC 14 + glibc mismatch: __pthread_cond_s changed but _GTHREAD_COND_INIT wasn't updated
find /usr/include/c++ -name "gthr-posix.h" | xargs sed -i 's/define _GTHREAD_COND_INIT PTHREAD_COND_INITIALIZER/define _GTHREAD_COND_INIT {}/' 2>/dev/null || true
find /usr/include/c++ -name "concurrence.h" | xargs sed -i 's/= _GTHREAD_COND_INIT/= {}/' 2>/dev/null || true

cmake -S . -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_FLAGS="-w" \
    -DCMAKE_CXX_FLAGS="-w -fpermissive" \
    -DENABLE_CTEST=OFF \
    -DBUILD_SHARED_LIBS=OFF \
    -DENABLE_OPT=OFF \
    -DENABLE_SPVREMAPPER=OFF \
    -DGLSLANG_TESTS=OFF \
    -DENABLE_HLSL=OFF
cmake --build build -j$(nproc)
DESTDIR="$1" cmake --install build
