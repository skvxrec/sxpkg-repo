#!/bin/sh
# Fix GCC 14 + glibc mismatch: __pthread_cond_s layout changed
# gthr-default.h defines __GTHREAD_COND_INIT = PTHREAD_COND_INITIALIZER which is now wrong
find /usr/include/c++ \( -name "gthr-default.h" -o -name "gthr-posix.h" \) \
    | xargs sed -i '/define __GTHREAD_COND_INIT PTHREAD_COND_INITIALIZER/d' 2>/dev/null || true
# Also patch concurrence.h directly as fallback
find /usr/include/c++ -name "concurrence.h" \
    | xargs sed -i 's/= __GTHREAD_COND_INIT/= {}/' 2>/dev/null || true

cmake -S . -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_FLAGS="-w" \
    -DCMAKE_CXX_FLAGS="-w -fpermissive" \
    -DENABLE_CTEST=OFF \
    -DBUILD_SHARED_LIBS=OFF \
    -DENABLE_OPT=OFF \
    -DENABLE_SPVREMAPPER=OFF \
    -DGLSLANG_TESTS=OFF \
    -DENABLE_HLSL=OFF
cmake --build build -j$(nproc)
DESTDIR="$1" cmake --install build
