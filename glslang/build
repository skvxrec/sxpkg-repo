#!/bin/sh
# GCC 14 + glibc mismatch: __pthread_cond_s changed but _GTHREAD_COND_INIT wasn't updated
sed -i 's/= _GTHREAD_COND_INIT/= {}/' /usr/include/c++/14.2.0/ext/concurrence.h 2>/dev/null || true

cmake -S . -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_FLAGS="-w" \
    -DCMAKE_CXX_FLAGS="-w -fpermissive" \
    -DENABLE_CTEST=OFF \
    -DBUILD_SHARED_LIBS=OFF \
    -DENABLE_OPT=OFF \
    -DENABLE_SPVREMAPPER=OFF \
    -DGLSLANG_TESTS=OFF \
    -DENABLE_HLSL=OFF
cmake --build build -j$(nproc)
DESTDIR="$1" cmake --install build
