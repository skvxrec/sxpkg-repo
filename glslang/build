#!/bin/sh
# Remove __GTHREAD_COND_INIT so concurrence.h falls back to dynamic init via
# __GTHREAD_COND_INIT_FUNCTION (pthread_cond_init), avoiding the glibc struct mismatch
find /usr/include/c++ -name "gthr-posix.h" | xargs sed -i '/define __GTHREAD_COND_INIT PTHREAD_COND_INITIALIZER/d' 2>/dev/null || true

cmake -S . -B build \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_FLAGS="-w" \
    -DCMAKE_CXX_FLAGS="-w -fpermissive" \
    -DENABLE_CTEST=OFF \
    -DBUILD_SHARED_LIBS=OFF \
    -DENABLE_OPT=OFF \
    -DENABLE_SPVREMAPPER=OFF \
    -DGLSLANG_TESTS=OFF \
    -DENABLE_HLSL=OFF
cmake --build build -j$(nproc)
DESTDIR="$1" cmake --install build
