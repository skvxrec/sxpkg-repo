#!/bin/sh
./configure --libdir=/usr/lib64 --prefix=/usr --sbindir=/sbin --sysconfdir=/etc \
  --disable-efiemu --disable-grub-themes --disable-nls \
  --with-platform=pc --target=x86_64
touch grub-core/extra_deps.lst
make -j$(nproc)
make DESTDIR="$1" install

make distclean
./configure --libdir=/usr/lib64 --prefix=/usr --sbindir=/sbin --sysconfdir=/etc \
  --disable-efiemu --disable-grub-themes --disable-nls \
  --with-platform=efi --target=x86_64
touch grub-core/extra_deps.lst
make -j$(nproc)
make DESTDIR="$1" install
